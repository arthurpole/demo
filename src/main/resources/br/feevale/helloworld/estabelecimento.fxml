<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="TOP_CENTER" prefHeight="480.0" prefWidth="640.0" spacing="12.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="br.feevale.helloworld.EstabelecimentoController">
    <children>
        <Label style="-fx-font-size: 22px; -fx-font-weight: bold;" text="Estabelecimento - Atendimentos" />
        <ListView fx:id="atendimentosListView" prefHeight="150.0" prefWidth="560.0" />
        <HBox alignment="CENTER" spacing="8.0">
            <children>
                <ComboBox fx:id="statusComboBox" prefWidth="180.0" />
                <Button mnemonicParsing="false" onAction="#atualizarStatus" text="Atualizar status" />
                <Button mnemonicParsing="false" onAction="#carregarAtendimentos" text="Recarregar" />
            </children>
        </HBox>
        <Label fx:id="detalhesLabel" prefHeight="130.0" prefWidth="560.0" text="Selecione um atendimento para visualizar os itens." />
        <Label fx:id="mensagemLabel" text="Nenhum atendimento selecionado." />
        <Button mnemonicParsing="false" onAction="#abrirMenu" text="Voltar ao menu" />
    </children>
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
</VBox>
