<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="TOP_CENTER" prefHeight="480.0" prefWidth="640.0" spacing="12.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="br.feevale.helloworld.ClienteController">
   <children>
      <Label style="-fx-font-size: 22px; -fx-font-weight: bold;" text="Cliente - Pedido" />
      <Label text="Escolha uma opcao de interacao:" />
      <HBox alignment="CENTER" spacing="8.0">
         <children>
            <ComboBox fx:id="opcoesComboBox" prefWidth="260.0" />
            <Button mnemonicParsing="false" onAction="#adicionarItem" text="Adicionar" />
         </children>
      </HBox>
      <ListView fx:id="itensListView" prefHeight="180.0" prefWidth="560.0" />
      <HBox alignment="CENTER" spacing="8.0">
         <children>
            <Button mnemonicParsing="false" onAction="#removerItem" text="Remover item" />
            <Button mnemonicParsing="false" onAction="#cancelarPedido" text="Cancelar pedido" />
         </children>
      </HBox>
      <Label fx:id="resumoLabel" style="-fx-font-size: 15px; -fx-font-weight: bold;" text="Itens: 0 | Total: R$ 0,00" />
      <Label fx:id="mensagemLabel" text="Monte seu pedido e confirme para gerar o atendimento." />
      <HBox alignment="CENTER" spacing="8.0">
         <children>
            <Button mnemonicParsing="false" onAction="#concluirPedido" text="Confirmar pedido" />
            <Button mnemonicParsing="false" onAction="#abrirMenu" text="Voltar ao menu" />
         </children>
      </HBox>
   </children>
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
</VBox>
