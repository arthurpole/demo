<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefHeight="520.0" prefWidth="720.0" spacing="22.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="br.feevale.helloworld.MenuController">
   <children>
      <Label style="-fx-font-size: 26px; -fx-font-weight: bold;" text="Sistema de Atendimento" />
      <Label style="-fx-font-size: 15px;" text="Selecione o tipo de acesso" />
      <HBox alignment="CENTER" spacing="16.0">
         <children>
            <Button mnemonicParsing="false" onAction="#abrirTelaCliente" prefHeight="48.0" prefWidth="190.0" text="Sou Cliente" />
            <Button mnemonicParsing="false" onAction="#abrirTelaEstabelecimento" prefHeight="48.0" prefWidth="190.0" text="Sou Estabelecimento" />
         </children>
      </HBox>
   </children>
   <padding>
      <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
   </padding>
</VBox>
